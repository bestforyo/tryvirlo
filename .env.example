# ====================================
# Supabase Configuration
# ====================================
# Get these from: https://supabase.com/dashboard
# 1. Create a new project
# 2. Go to Project Settings > API
# 3. Copy the values below

NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database (Supabase PostgreSQL)
# Get from: Supabase Project Settings > Database > Connection String
# Use "Transaction" mode for Prisma
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
# Direct connection (for migrations/seed)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ====================================
# Google OAuth
# ====================================
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID with authorized redirect URI
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ====================================
# Payment - Creem.io (Primary)
# ====================================
CREEMIO_API_KEY="your-creemio-api-key"
CREEMIO_WEBHOOK_SECRET="your-webhook-secret"
CREEMIO_WEBHOOK_URL="https://tryvirlo.com/api/webhooks/payment"

# ====================================
# Payment - Dodopayment (Backup)
# ====================================
DODOPAYMENT_API_KEY="your-dodopayment-api-key"
DODOPAYMENT_WEBHOOK_SECRET="your-dodopayment-webhook-secret"

# ====================================
# AI Provider API Keys
# ====================================
# Get from respective provider dashboards

# PiAPI - Text to Video
PIAPI_API_KEY="your-piapi-api-key"
PIAPI_BASE_URL="https://api.piapi.ai"

# GRS AI - Text to Video
GRSAI_API_KEY="your-grsai-api-key"
GRSAI_BASE_URL="https://api.grsai.ai"

# Pic2API - Image to Video
PIC2API_API_KEY="your-pic2api-api-key"
PIC2API_BASE_URL="https://api.pic2api.com"

# Apimart - Text to Image
APIMART_API_KEY="your-apimart-api-key"
APIMART_BASE_URL="https://api.apimart.io"

# Apipod - Video Upscale
APIPOD_API_KEY="your-apipod-api-key"
APIPOD_BASE_URL="https://api.apipod.com"

# ====================================
# Cloudflare R2 Storage
# ====================================
# Get from: https://dash.cloudflare.com/r2
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="tryvirlo-assets"
R2_PUBLIC_URL="https://your-r2-domain.com"

# ====================================
# Upstash QStash (Job Queue)
# ====================================
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"
QSTASH_TOKEN="your-qstash-token"

# ====================================
# Monitoring & Analytics
# ====================================
SENTRY_DSN="your-sentry-dsn"
POSTHOG_KEY="your-posthog-key"

# ====================================
# Email (Resend)
# ====================================
RESEND_API_KEY="your-resend-api-key"

# ====================================
# App Configuration
# ====================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ====================================
# Cron Jobs Security
# ====================================
CRON_SECRET="generate-a-random-string-here"
