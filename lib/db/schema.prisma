// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTH
// ============================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  googleId          String?   @unique @map("google_id")
  name              String?
  avatar            String?
  plan              Plan      @default(FREE)
  creditsBalance    Int       @default(50) @map("credits_balance")
  creditsMonthlyReset Int     @default(500) @map("credits_monthly_reset")
  role              Role      @default(USER)
  emailVerified     Boolean   @default(false) @map("email_verified")
  lastCreditsReset  DateTime? @map("last_credits_reset")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  subscriptions      Subscription[]
  generations        Generation[]
  creditsTransactions CreditsTransaction[]
  assets             Asset[]
  adminUser          AdminUser?
  adminLogs          AdminLog[]

  @@map("users")
}

model AdminUser {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  permissions  Json     // { canManageUsers: boolean, canViewAnalytics: boolean, ... }
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_users")
}

// ============================================
// SUBSCRIPTIONS & PAYMENTS
// ============================================

model Subscription {
  id                    String              @id @default(uuid())
  userId                String              @map("user_id")
  provider              PaymentProvider     @default(CREEMIO)
  providerSubscriptionId String?             @unique @map("provider_subscription_id")
  providerCustomerId    String?             @map("provider_customer_id")
  plan                  SubscriptionPlan
  status                SubscriptionStatus
  currentPeriodStart    DateTime?           @map("current_period_start")
  currentPeriodEnd      DateTime?           @map("current_period_end")
  cancelAtPeriodEnd     Boolean             @default(false) @map("cancel_at_period_end")
  creditsGranted        Int                 @default(0) @map("credits_granted")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider, providerSubscriptionId])
  @@map("subscriptions")
}

model CreditsTransaction {
  id          String              @id @default(uuid())
  userId      String              @map("user_id")
  amount      Int                 // Positive for credits added, negative for consumed
  type        CreditsType
  referenceId String?             @map("reference_id")
  description String?
  metadata    Json?
  createdAt   DateTime            @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("credits_transactions")
}

// ============================================
// GENERATIONS & MODELS
// ============================================

model Model {
  id               String   @id
  provider         String   // piapi, grsai, pic2api, apimart, apipod
  name             String
  type             GenerationType // TEXT_TO_VIDEO, IMAGE_TO_VIDEO, TEXT_TO_IMAGE, VIDEO_UPSCALE
  quality          String?  // 720p, 1080p, 4K
  speedTier        String?  // fast, medium, slow
  isActive         Boolean  @default(true) @map("is_active")
  pricing          Json     // { "10s-720p": 50, "10s-1080p": 100, ... }
  apiModelId       String?  @map("api_model_id")
  fallbackModelId  String?  @map("fallback_model_id")
  createdAt        DateTime @default(now()) @map("created_at")

  generations Generation[]

  @@index([type, isActive])
  @@map("models")
}

model Generation {
  id                  String             @id @default(uuid())
  userId              String             @map("user_id")
  provider            String             // piapi, grsai, pic2api, apimart, apipod
  modelId             String             @map("model_id")
  type                GenerationType
  prompt              String             @db.Text
  parameters          Json               // { duration: 10, quality: "1080p", aspectRatio: "16:9" }
  status              GenerationStatus   @default(PENDING)
  jobId               String?            @unique @map("job_id") // Provider's job ID
  resultUrl           String?            @map("result_url")
  resultStorageKey    String?            @map("result_storage_key")
  creditsConsumed     Int?               @map("credits_consumed")
  costUsd             Decimal?           @map("cost_usd") @db.Decimal(10, 4)
  videoDuration       Int?               @map("video_duration") // seconds
  videoQuality        String?            @map("video_quality") // 720p, 1080p, 4K
  videoAspectRatio    String?            @map("video_aspect_ratio") // 16:9, 9:16, 1:1
  fileSize            BigInt?            @map("file_size")
  errorMessage        String?            @map("error_message")
  startedAt           DateTime?          @map("started_at")
  completedAt         DateTime?          @map("completed_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  model    Model    @relation(fields: [modelId], references: [id])
  assets   Asset[]

  @@index([userId, status])
  @@index([status])
  @@index([createdAt])
  @@map("generations")
}

// ============================================
// ASSETS
// ============================================

model Asset {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  generationId  String?      @map("generation_id")
  type          AssetType    // video, image
  storageKey    String       @map("storage_key") // R2 key
  storageProvider String     @default("r2") @map("storage_provider")
  fileSize      BigInt?      @map("file_size")
  metadata      Json?        // { width, height, duration, format }
  expiresAt     DateTime?    @map("expires_at") // For free users
  createdAt     DateTime     @default(now()) @map("created_at")

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation Generation? @relation(fields: [generationId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("assets")
}

// ============================================
// LOGGING
// ============================================

model PaymentLog {
  id         String   @id @default(uuid())
  provider   PaymentProvider
  eventType  String   @map("event_type") // subscription.created, payment.succeeded, etc.
  eventId    String   @map("event_id") // Provider's event ID
  payload    Json
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([provider, eventId])
  @@index([processed])
  @@map("payment_logs")
}

model WebhookLog {
  id         String   @id @default(uuid())
  provider   String   // piapi, grsai, etc.
  eventType  String   @map("event_type")
  payload    Json
  processed  Boolean  @default(false)
  errorMessage String? @map("error_message")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([provider, processed])
  @@map("webhooks_log")
}

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  action     String   // user.banned, generation.deleted, etc.
  targetType String?  @map("target_type") // user, generation, subscription
  targetId   String?  @map("target_id")
  changes    Json?    // { before: {}, after: {} }
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@map("admin_logs")
}

// ============================================
// ENUMS
// ============================================

enum Plan {
  FREE
  LITE
  PRO
  ENTERPRISE
}

enum Role {
  USER
  ADMIN
}

enum PaymentProvider {
  CREEMIO
  DODOPAYMENT
}

enum SubscriptionPlan {
  LITE_MONTHLY
  LITE_YEARLY
  PRO_MONTHLY
  PRO_YEARLY
  ENTERPRISE_MONTHLY
  ENTERPRISE_YEARLY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELED
  PAST_DUE
  INCOMPLETE
}

enum CreditsType {
  // Addition
  PURCHASE
  SUBSCRIPTION
  REFUND
  BONUS
  REFERRAL
  // Consumption
  GENERATION
  REFUND_GENERATION
  ADJUSTMENT
}

enum GenerationType {
  TEXT_TO_VIDEO
  IMAGE_TO_VIDEO
  TEXT_TO_IMAGE
  VIDEO_UPSCALE
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  TIMEOUT
}

enum AssetType {
  VIDEO
  IMAGE
}
